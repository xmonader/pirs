// Sympy detector for SWE-bench `bin/test` + `sympy/` layout.
//
// Bare FAIL_TO_PASS ids (`test_mod`) are function names, not path globs.
// We resolve `def test_foo(` under sympy/**/test_*.py and invoke the function
// directly for stable per-id pass/fail (avoids bin/test path-glob + flaky whole-file runs).
//
// Note: bin/test does not support pytest `-q`.

fn detect() {
    let specs = [];
    if path_exists("bin/test") && path_exists("sympy") {
        let py = "PY=$(command -v python3 || command -v python); ";
        let b64 = "";
        specs.push(#{
            framework: "sympy",
            install: [],
            list_cmd: py + "test -f bin/test && \"$PY\" -c \"import sympy; print('sympy', sympy.__version__)\"",
            // Write into /testbed (writable); /tmp may be non-writable for the harness user.
            test_cmd: py + "echo " + b64 + " | base64 -d > /testbed/.pirs_sympy_run.py && \"$PY\" /testbed/.pirs_sympy_run.py {tests} {junit}",
            shell_quote_tests: true,
            timeout_secs: 1800,
            parallel: false,
        });
    }
    specs
}
